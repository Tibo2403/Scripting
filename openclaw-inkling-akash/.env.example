# Image Docker construite et poussée dans un registre public
OPENCLAW_IMAGE=ghcr.io/USER/openclaw-inkling-akash:latest

# Clé de l'API Inkling / AI Gateway
INKLING_API_KEY=change-me
INKLING_BASE_URL=https://ai-gateway.vercel.sh/v1
INKLING_MODEL=thinkingmachines/inkling

# Token fort utilisé pour protéger la gateway OpenClaw
OPENCLAW_GATEWAY_TOKEN=change-me-with-openssl-rand-hex-32
