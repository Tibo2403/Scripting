{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": {
        "primary": "ollama/llama3.2:3b-instruct-q4_K_M"
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.2:3b-instruct-q4_K_M",
            "name": "Llama 3.2 3B Instruct Q4_K_M",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 16384,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "apply_patch"
    ],
    "deny": [
      "exec",
      "process",
      "browser",
      "canvas",
      "nodes",
      "sessions_spawn",
      "web_search",
      "web_fetch"
    ],
    "exec": {
      "security": "deny",
      "ask": "always"
    },
    "elevated": {
      "enabled": false
    }
  }
}
